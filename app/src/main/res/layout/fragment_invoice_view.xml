<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- The "paper" invoice -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Gold gradient top bar -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:background="@drawable/gold_gradient" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Shop header + invoice meta -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/shopName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/navy"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:fontFamily="serif"
                                    tools:text="Shri Swarna Jewellers" />

                                <TextView
                                    android:id="@+id/shopAddress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"
                                    tools:text="123 Bazaar Road, Jaipur" />

                                <TextView
                                    android:id="@+id/shopMeta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"
                                    tools:text="Ph: +91 98765 43210 | GSTIN: 08ABCDE1234F1Z5" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="INVOICE"
                                    android:textColor="@color/gold_dark"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.1" />

                                <TextView
                                    android:id="@+id/invoiceNumber"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/navy"
                                    android:textStyle="bold"
                                    android:textSize="16sp"
                                    tools:text="#INV-001" />

                                <TextView
                                    android:id="@+id/invoiceDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"
                                    tools:text="29/06/2026" />
                            </LinearLayout>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginVertical="12dp" android:background="@color/divider" />

                        <!-- Customer -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/customer_details"
                            android:textColor="@color/gold_dark"
                            android:textStyle="bold"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/customerLine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            tools:text="Anita Sharma  |  9876500011" />

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginVertical="12dp" android:background="@color/divider" />

                        <!-- Items table header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/cream"
                            android:padding="6dp"
                            android:orientation="horizontal">

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="2.4" android:text="Item" android:textStyle="bold"
                                android:textSize="11sp" android:textColor="@color/navy" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Wt(g)" android:textStyle="bold"
                                android:textSize="11sp" android:textColor="@color/navy" android:gravity="end" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1.2" android:text="Rate" android:textStyle="bold"
                                android:textSize="11sp" android:textColor="@color/navy" android:gravity="end" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1.2" android:text="Making" android:textStyle="bold"
                                android:textSize="11sp" android:textColor="@color/navy" android:gravity="end" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1.4" android:text="Total" android:textStyle="bold"
                                android:textSize="11sp" android:textColor="@color/navy" android:gravity="end" />
                        </LinearLayout>

                        <!-- Dynamic item rows injected here -->
                        <LinearLayout
                            android:id="@+id/itemsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginVertical="12dp" android:background="@color/divider" />

                        <!-- Totals -->
                        <LinearLayout
                            android:id="@+id/totalsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <!-- Notes + signature -->
                        <TextView
                            android:id="@+id/notesView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            tools:text="Notes: Advance received in cash." />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="28dp"
                            android:text="Authorized Signature"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Gold gradient bottom bar -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:background="@drawable/gold_gradient" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWhatsapp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/send_whatsapp"
                    app:icon="@drawable/ic_whatsapp"
                    app:iconTint="@color/white"
                    app:backgroundTint="@color/paid_success"
                    android:textColor="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/share_pdf"
                    app:icon="@drawable/ic_share"
                    style="@style/Widget.SwarnaBook.Button.Outline" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/print"
                    app:icon="@drawable/ic_print"
                    style="@style/Widget.SwarnaBook.Button.Outline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEdit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/edit_invoice"
                    app:icon="@drawable/ic_edit"
                    style="@style/Widget.SwarnaBook.Button.Outline" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkPaid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/mark_as_paid"
                app:icon="@drawable/ic_check"
                app:iconTint="@color/navy"
                style="@style/Widget.SwarnaBook.Button.Gold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
