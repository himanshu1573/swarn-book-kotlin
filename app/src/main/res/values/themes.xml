<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
      FONTS: Headlines use "serif" (Playfair-Display look) and body uses
      "sans-serif" (Lato look) so the project builds with zero external setup.
      To use the EXACT Playfair Display / Lato: in Android Studio do
      res > New > Font resource file > pick the font (it auto-adds the Google
      font provider cert array), then point fontFamily below at @font/playfair_display
      and @font/lato. No other code changes needed.
    -->

    <style name="Theme.SwarnaBook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand colors mapped to Material 3 roles -->
        <item name="colorPrimary">@color/navy</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/navy</item>
        <item name="colorOnPrimaryContainer">@color/gold</item>

        <item name="colorSecondary">@color/gold_dark</item>
        <item name="colorOnSecondary">@color/navy</item>
        <item name="colorSecondaryContainer">@color/gold</item>
        <item name="colorOnSecondaryContainer">@color/navy</item>

        <item name="android:colorBackground">@color/cream</item>
        <item name="colorSurface">@color/cream_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorError">@color/balance_due</item>
        <item name="colorOutline">@color/divider</item>

        <item name="android:statusBarColor">@color/navy</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineMedium">@style/Text.Headline</item>
        <item name="textAppearanceTitleLarge">@style/Text.Title</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <!-- Splash uses the same theme; brand splash drawn manually in SplashFragment -->
    <style name="Theme.SwarnaBook.Splash" parent="Theme.SwarnaBook">
        <item name="android:statusBarColor">@color/navy</item>
    </style>

    <style name="Text.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">serif</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">serif</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Gold primary button -->
    <style name="Widget.SwarnaBook.Button.Gold" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/gold</item>
        <item name="android:textColor">@color/navy</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.SwarnaBook.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/navy</item>
        <item name="strokeColor">@color/gold_dark</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.SwarnaBook.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/cream_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.SwarnaBook.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/gold_dark</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>
</resources>
